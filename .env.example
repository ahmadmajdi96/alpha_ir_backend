DATABASE_URL=postgresql+psycopg2://shelfvision:shelfvision@db:5432/shelfvision
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_KEY=replace-with-strong-api-key
UPLOAD_DIR=/data/storage

CORS_ALLOW_ORIGINS=*
APP_PORT=8010
MINIO_ENDPOINT=minio:9090
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9090
MINIO_DEFAULT_BUCKETS=shelf-images,sku-training-images
MINIO_API_PORT=9090
MINIO_CONSOLE_PORT=9091
